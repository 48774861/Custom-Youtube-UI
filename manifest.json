
{
  "manifest_version": 3,
  "name": "YouTube Custom Interface",
  "description": "Custom YouTube layout with cinema mode, sidebar navigation, and UI cleanup enhancements.",
  "version": "1.0",

  "permissions": ["storage"],

  "host_permissions": ["*://*.youtube.com/*"],

  "web_accessible_resources": [
    {
      "resources": ["youtube.co.png", "history.png", "watchlater.png", "villagevideo.mp4"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js", "searchbar.js"],
      "css": ["styles.css"]
    }
  ]
}